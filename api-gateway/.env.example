# API Gateway Environment Variables
# Copy this file to .env and update values as needed

# Gateway Port
PORT=3000

# Service URLs (update if running on different hosts/ports)
MOVIE_SERVICE_URL=http://localhost:3001
CINEMA_SERVICE_URL=http://localhost:3002
BOOKING_SERVICE_URL=http://localhost:3003
USER_SERVICE_URL=http://localhost:3004

# JWT Configuration (must match across all services)
JWT_SECRET=cinebook_dev_secret_change_me
