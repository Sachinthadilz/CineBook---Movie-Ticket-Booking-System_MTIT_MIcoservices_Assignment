      "name": "1. User Service",
      "item": [
        {
          "name": "Register Normal User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  if (data.user && data.user._id) pm.environment.set('userId', data.user._id);",
                  "  if (data.user && data.user.email) pm.environment.set('userEmail', data.user.email);",
                  "  console.log('Registration successful. Please login to get a token.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nadeesha Perera\",\n  \"email\": \"nadeesha.perera@example.com\",\n  \"password\": \"SecurePass123\",\n  \"phone\": \"0772345678\"\n}"
            },
            "url": {
              "raw": "{{userServiceUrl}}/users/register",
              "host": ["{{userServiceUrl}}"],
              "path": ["users", "register"]
            }
          }
        },
        {
